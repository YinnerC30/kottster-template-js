# ─────────────────────────────────────────────────────────────────────────────
# Kottster – Environment Variables Template
#
# Copy this file to .env and fill in the values before running locally.
# In Dokploy, set these in the "Environment Variables" tab of your service.
# NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
HOST_PORT=5480          # Host port that maps to the container's 5480

# ── Kottster Security (REQUIRED) ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_SALT=change-me-to-another-random-secret

# ── Admin credentials (REQUIRED) ─────────────────────────────────────────────
ROOT_USERNAME=admin
ROOT_PASSWORD=change-me-to-a-strong-password
